# OpenRouter API Key
# Få din nøgle fra: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# Supabase Configuration
# Opret et projekt på: https://supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Discord Configuration (Valgfrit)
# Opret en bot på: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id

# Slack Configuration (Valgfrit)
# Opret en app på: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=your_slack_channel_id

# n8n Configuration
# Generer en tilfældig encryption key (mindst 32 tegn)
N8N_ENCRYPTION_KEY=generate_a_random_32_character_key_here
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_to_a_strong_password

# Postgres Configuration (Valgfrit - til produktion)
# POSTGRES_PASSWORD=change_this_to_a_strong_password
